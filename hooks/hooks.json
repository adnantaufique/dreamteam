{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent|Task|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/dreamteam-run-policy.js\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/dreamteam-compact-rearm.js\""
          }
        ]
      }
    ]
  }
}
